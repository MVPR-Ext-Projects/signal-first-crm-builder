# =============================================================================
# Signal-first CRM template — required environment variables
# =============================================================================
# Copy to .env.local and fill in. Most of these auto-populate when you
# `vercel link` + provision Upstash Redis + Neon Postgres via Vercel
# Marketplace. The app-level secrets you set yourself.
# =============================================================================

# --- App-level secrets (you set these) --------------------------------------

# 32 random bytes, base64-encoded. Used for AES encryption of
# webhook secrets and CRM tokens at rest.
#   openssl rand -base64 32
ENCRYPTION_KEY=

# Long random string. Crons hitting Next.js routes verify this in the
# Authorization header.
#   openssl rand -hex 32
CRON_SECRET=

# Anthropic API key. Used by the persona classifier, the DM drafter,
# and the writing-style analyzer.
ANTHROPIC_API_KEY=

# Optional: outbound email sending.
RESEND_API_KEY=

# --- Storage (auto-provisioned by Vercel Marketplace) -----------------------

# Upstash Redis — stores workspace configs at workspace:<id>:config.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Postgres — the projection (contacts, signals, companies, outreach_log,
# style_fingerprints, etc.).
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=

# --- Per-workspace integrations (set via the dashboard, not env) ------------
# DO NOT put HubSpot tokens / Teamfluence keys / Dripify secrets here.
# Those live encrypted in the workspace config in Upstash and are set
# through the dashboard's Settings pages after you seed your workspace.
